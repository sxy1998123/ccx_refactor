{
  "name": "ccx-desktop",
  "version": "0.1.0",
  "description": "CCX desktop application",
  "main": "./out/main/index.js",
  "author": "CCX",
  "homepage": "./",
  "scripts": {
    "dev": "node scripts/run-electron-vite.mjs dev",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && node scripts/run-electron-vite.mjs build",
    "build:fullstack": "powershell -ExecutionPolicy Bypass -File ../scripts/package-win-unpacked.ps1",
    "package:win-unpacked": "npm run build && electron-builder --win --dir --config electron-builder.yml",
    "preview": "node scripts/run-electron-vite.mjs preview"
  },
  "devDependencies": {
    "@swc/core": "1.15.8",
    "@types/node": "25.6.0",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-vue": "6.0.6",
    "electron": "39.8.8",
    "electron-builder": "^26.8.1",
    "electron-vite": "5.0.0",
    "element-plus": "^2.13.7",
    "playwright": "^1.59.1",
    "three": "^0.184.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vue": "^3.5.32",
    "vue-tsc": "3.2.6"
  }
}
